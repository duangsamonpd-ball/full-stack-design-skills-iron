---
// Reusable Material 3 filled text field. Utility-first: all styling is inline Tailwind here,
// reused by reusing the component. Rendered at build time; ships no JS of its own.
interface Props {
  id: string;
  label: string;
  icon: string;
  type?: string;
  autocomplete?: string;
  name?: string;
}
const { id, label, icon, type = 'text', autocomplete, name = id } = Astro.props;
---
<div>
  <div class="field relative">
    <input
      id={id}
      name={name}
      type={type}
      autocomplete={autocomplete}
      required
      placeholder=" "
      class="peer h-14 w-full rounded-t-[4px] border-b border-outline bg-sc-highest pl-12 pr-4 pt-5 pb-1 text-sm text-on-surface caret-primary outline-none transition-colors hover:border-on-surface focus:border-b-2 focus:border-primary placeholder:text-transparent"
    />
    <label
      for={id}
      class="pointer-events-none absolute left-12 top-1.5 text-xs text-on-surface-variant transition-all duration-150 peer-placeholder-shown:top-4 peer-placeholder-shown:text-sm peer-focus:top-1.5 peer-focus:text-xs peer-focus:font-medium peer-focus:text-primary"
    >{label}</label>
    <span class="lead material-symbols-outlined absolute left-3 top-4 text-on-surface-variant transition-colors peer-focus:text-primary" aria-hidden="true">{icon}</span>
  </div>
  <p id={`${id}-err`} class="mt-1 hidden items-center gap-1 px-4 text-xs text-error"></p>
</div>
